<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Masuk — KomikKu</title>
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
.auth-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px 16px;background:radial-gradient(ellipse at 60% 40%, rgba(34,153,221,0.07) 0%, transparent 70%), var(--bg)}
.auth-card{background:rgba(32,32,35,0.6);border:1px solid rgba(63,63,70,0.5);border-radius:24px;padding:48px;width:100%;max-width:440px}
.auth-logo{font-family:'Bangers',cursive;font-size:28px;letter-spacing:2px;text-align:center;margin-bottom:6px}
.auth-logo span{color:#2299DD}
.auth-sub{text-align:center;color:#737373;font-size:13px;margin-bottom:36px}
.form-group{margin-bottom:20px}
.form-label{font-size:13px;font-weight:700;color:#a3a3a3;display:block;margin-bottom:8px}
.form-input{
  width:100%;background:#1a1a1d;border:1px solid rgba(63,63,70,0.6);
  color:#f5f5f5;padding:12px 16px;border-radius:12px;font-size:14px;
  font-family:'Nunito',sans-serif;outline:none;transition:border-color .2s;
}
.form-input:focus{border-color:#2299DD}
.form-input::placeholder{color:#525252}
.form-submit{width:100%;padding:14px;background:#2299DD;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;font-family:'Nunito',sans-serif;cursor:pointer;transition:background .2s;margin-top:4px}
.form-submit:hover{background:#1A7FB8}
.auth-footer{text-align:center;margin-top:24px;font-size:13px;color:#737373}
.auth-footer a{color:#2299DD;font-weight:700;text-decoration:none}
.divider{display:flex;align-items:center;gap:12px;margin:24px 0;color:#525252;font-size:12px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:rgba(63,63,70,0.5)}
.error-msg{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.4);color:#fca5a5;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:20px}
</style>
</head>
<body>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">✦ <span>KOMIK</span>KU</div>
    <p class="auth-sub">Masuk untuk lanjut membaca</p>

    <% if(locals.error) { %>
    <div class="error-msg">⚠️ <%= error %></div>
    <% } %>

    <form id="loginForm">
      <div class="form-group">
        <label class="form-label">Email atau Username</label>
        <input type="text" name="emailOrUsername" id="emailOrUsername" class="form-input" placeholder="masukkan email atau username" required>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" id="password" class="form-input" placeholder="Masukkan password" required>
        <div style="text-align:right;margin-top:8px">
          <a href="/auth/forgot-password" style="color:#2299DD;font-size:12px;font-weight:700;text-decoration:none">Lupa password?</a>
        </div>
      </div>
      <button type="submit" class="form-submit">Masuk →</button>
    </form>

    <div class="divider">atau</div>

    <div style="text-align:center">
      <a href="/browse" style="color:#a3a3a3;font-size:13px;text-decoration:none">
        Lanjut sebagai <strong style="color:#f5f5f5">Tamu</strong> →
      </a>
    </div>

    <div class="auth-footer">
      Belum punya akun? <a href="/auth/register">Daftar sekarang</a>
    </div>
  </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const emailOrUsername = document.getElementById('emailOrUsername').value;
  const password = document.getElementById('password').value;
  
  try {
    const response = await fetch('/auth/login', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ emailOrUsername, password })
    });
    
    const data = await response.json();
    
    if (data.success) {
      Swal.fire({
        icon: 'success',
        title: 'Login Berhasil!',
        text: data.message || 'Selamat datang kembali di KomikKu!',
        background: '#202023',
        color: '#f5f5f5',
        confirmButtonColor: '#2299DD',
        timer: 2000,
        showConfirmButton: false
      });

      setTimeout(() => {
        if (data.role === 'admin') {
          window.location.href = '/admin';
        } else if (data.role === 'creator') {
          window.location.href = '/author';
        } else {
          window.location.href = '/';
        }
      }, 2000);

    } else {
      Swal.fire({
        icon: 'error',
        title: 'Akses Ditolak!',
        text: data.error || 'Email atau password salah.',
        background: '#202023',
        color: '#f5f5f5',
        confirmButtonColor: '#ef4444'
      });
    }
  } catch (err) {
    Swal.fire({
      icon: 'warning',
      title: 'Terjadi Kesalahan!',
      text: err.message,
      background: '#202023',
      color: '#f5f5f5',
      confirmButtonColor: '#2299DD'
    });
  }
});
</script>

</body>
</html>