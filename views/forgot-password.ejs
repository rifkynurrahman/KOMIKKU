<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Lupa Password</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:#18181B; color:#f5f5f5; font-family:sans-serif; text-align:center; padding-top:100px;">
    <div style="max-width:400px; margin:0 auto; background:#1a1a1e; padding:30px; border-radius:10px;">
        <h2>🔒 Lupa Password</h2>
        <p style="color:#a1a1aa; font-size:14px;">Masukkan email terdaftar kamu untuk menerima link reset password.</p>
        
        <form action="/auth/forgot-password" method="POST">
            <input type="email" name="email" placeholder="Masukkan email kamu" required 
                   style="width:100%; padding:10px; margin:15px 0; background:#09090b; border:1px solid #27272a; color:#fff; border-radius:5px;">
            <button type="submit" style="background:#2299DD; color:white; border:none; padding:10px 20px; border-radius:5px; cursor:pointer; width:100%;">
                Kirim Link Reset
            </button>
        </form>
        <br>
        <a href="/auth/login" style="color:#2299DD; text-decoration:none; font-size:14px;">← Kembali ke Login</a>
    </div>
</body>
</html>