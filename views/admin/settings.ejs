<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <title>Pengaturan - Admin</title>
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <small>SET MANUAL VIA DATABASE</small>
                <div class="admin-brand">🛡️ Admin Panel</div>
            </div>
            
            <div class="sidebar-menu">
                <label>NAVBAR</label>
                <a href="/"><i class="icon">🏠</i> Beranda</a>
                <a href="/browse"><i class="icon">🧭</i> Browse</a>
                <a href="/admin"><i class="icon">🛡️</i> Dashboard <span class="badge-khusus">Khusus</span></a>
                <a href="/auth/profile"><i class="icon">👤</i> Profil Utama</a>
                
                <label style="margin-top:20px">MANAGEMENT</label>
                <a href="/admin/users"><i class="icon">👥</i> Kelola User</a>
                <a href="/admin/comics"><i class="icon">📚</i> Kelola Komik</a>
                <a href="/admin/reports">🚩 Laporan Konten</a> 
                <a href="/admin/settings" class="active">⚙️ Pengaturan Sistem</a>
                
                <label style="margin-top:20px">AKSI</label>
                <a href="/auth/logout" style="color: #ef4444;"><i class="icon">🚪</i> Keluar</a>
            </div>
        </nav>

        <main class="admin-main">
            <header class="main-header">
                <h1>⚙️ Pengaturan Sistem</h1>
            </header>
            
            <section class="internal-profile">
                <form action="/admin/settings/update" method="POST" class="admin-form">
                    
                    <div class="form-group">
                        <label>Nama Situs</label>
                        <input type="text" name="siteName" value="<%= settings.siteName %>">
                    </div>
                    
                    <div class="form-group">
                        <label>Email Kontak</label>
                        <input type="email" name="contactEmail" value="<%= settings.contactEmail %>">
                    </div>
                    
                    <div class="form-group">
                        <label>Mode Maintenance</label>
                        <select name="maintenanceMode" style="width:100%; padding:10px; background:#121214; color:white; border: 1px solid rgba(63, 63, 70, 0.4); border-radius:10px; cursor: pointer;">
                            <option value="false" <%= !settings.maintenanceMode ? 'selected' : '' %>>Normal (Online)</option>
                            <option value="true" <%= settings.maintenanceMode ? 'selected' : '' %>>Maintenance (Offline)</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn-gold">Update Pengaturan</button>
                </form>
            </section>
        </main>
    </div>
</body>
</html>