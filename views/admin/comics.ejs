<!-- views/admin/comics.ejs -->
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <title>Kelola Komik - Admin Panel</title>
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <!-- Memanggil sidebar yang sama dengan halaman users -->
        <%- include('sidebar_partial_admin') %> 

        <main class="admin-main" style="padding:20px; width:100%">
            <h2 style="color:#ffcc00; font-family:'Bangers'; letter-spacing:1px">📚 Daftar Semua Komik</h2>
            <p style="color:#888; font-size:14px">Pantau dan kelola seluruh konten komik yang ada di platform.</p>

            <table border="1" style="width:100%; margin-top:20px; border-collapse:collapse; color:#f5f5f5; border: 1px solid #333;">
                <thead>
                    <tr style="background:#252525; text-align:left">
                        <th style="padding:15px">Cover</th>
                        <th>Judul Komik</th>
                        <th>Kreator / Uploaded By</th>
                        <th>Genre</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (comics && comics.length > 0) { %>
                        <% comics.forEach(c => { %>
                        <tr style="border-bottom:1px solid #333">
                            <td style="padding:10px; width:80px">
                                <img src="/<%= c.coverImage %>" alt="Cover" style="width:60px; height:80px; object-fit:cover; border-radius:4px; border:1px solid #444">
                            </td>
                            <td style="font-weight:bold"><%= c.title %></td>
                            <td>
                                <span style="color:#2299DD">@<%= c.uploadedBy ? c.uploadedBy.username : 'Anonim' %></span>
                            </td>
                            <td>
                                <% if(c.genres) { %>
                                    <small style="color:#aaa"><%= c.genres.join(', ') %></small>
                                <% } %>
                            </td>
                            <td>
                                <div style="display:flex; gap:10px">
                                    <a href="/komik/<%= c._id %>" target="_blank" style="color:#ffcc00; text-decoration:none; font-size:13px">Buka</a>
                                    
                                    <!-- Form Hapus Komik oleh Admin -->
                                    <form action="/admin/comics/delete/<%= c._id %>" method="POST" onsubmit="return confirm('Hapus komik ini secara permanen?')">
                                        <button type="submit" style="color:#ff4444; background:none; border:none; cursor:pointer; font-size:13px; font-family:inherit; font-weight:bold">Hapus</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="padding:40px; text-align:center; color:#666">Belum ada komik yang diupload.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>
</body>
</html>