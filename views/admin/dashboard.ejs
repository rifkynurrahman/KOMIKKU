<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <title>Admin Panel - KomikKu</title>
    <style>
        /* Tambahan style opsional untuk mempercantik kartu statistik */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }
        .stats-card {
            background: #1a1a1e;
            border: 1px solid rgba(63, 63, 70, 0.4);
            padding: 24px;
            border-radius: 14px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .stats-card h4 { margin: 0; color: #a1a1aa; font-size: 14px; font-weight: 600; }
        .stats-card .stats-number { font-size: 28px; font-weight: 900; color: #2299DD; }
    </style>
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <small>SET MANUAL VIA DATABASE</small>
                <div class="admin-brand">🛡️ Admin Panel</div>
            </div>
            
            <div class="sidebar-menu">
                <label>NAVBAR</label>
                <a href="/"><i class="icon">🏠</i> Beranda</a>
                <a href="/browse"><i class="icon">🧭</i> Browse</a>
                <a href="/admin" class="active"><i class="icon">🛡️</i> Dashboard <span class="badge-khusus">Khusus</span></a>
                <a href="/auth/profile"><i class="icon">👤</i> Profil Utama</a>
                
                <label style="margin-top:20px">MANAGEMENT</label>
                <a href="/admin/users"><i class="icon">👥</i> Kelola User</a>
                <a href="/admin/comics"><i class="icon">📚</i> Kelola Komik</a>
                
                <label style="margin-top:20px">AKSI</label>
                <a href="/auth/logout" style="color: #ef4444;"><i class="icon">🚪</i> Keluar</a>
            </div>
        </nav>

        <main class="admin-main">
            <header class="main-header">
                <h1>Dashboard Statistik</h1>
            </header>

            <div class="stats-grid">
                <div class="stats-card">
                    <h4>Total Pengguna</h4>
                    <div class="stats-number">✔ Aktif</div>
                </div>
                <div class="stats-card">
                    <h4>Komik Terbaca</h4>
                    <div class="stats-number">📚 Koleksi</div>
                </div>
                <div class="stats-card">
                    <h4>Status Server</h4>
                    <div class="stats-number" style="color: #10b981;">● Online</div>
                </div>
            </div>

            <section class="internal-profile">
                <h3>Kelola Profil Internal Admin</h3>
                <form action="/admin/profile/internal" method="POST" class="admin-form">
                    <div class="form-group">
                        <label>Ganti Email Admin</label>
                        <input type="email" name="email" value="<%= (locals.user && user.email) ? user.email : 'admin@komikku.com' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Ganti Password Baru</label>
                        <input type="password" name="password" placeholder="Isi jika ingin ganti">
                    </div>
                    <button type="submit" class="btn-gold">Simpan Perubahan</button>
                </form>
            </section>
        </main>

    </div>
</body>
</html>